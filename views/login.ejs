<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Shortify</title>
    <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
    <div class="container">
        <header class="header">
            <div class="brand">Shortify</div>
            <nav class="nav-links">
                <a href="/signup">Sign Up</a>
                <a href="/">Home</a>
            </nav>
        </header>

        <section class="hero">
            <div>
                <span class="status-chip">Welcome back</span>
                <h1>Log in and manage your links effortlessly.</h1>
                <p>Access your dashboard, shorten new URLs, and review link analytics with a clean and modern experience.</p>
            </div>
            <div class="card">
                <h2>Login to your account</h2>
                <form class="form-grid" method="POST" action="/user/login">
                    <div>
                        <label for="email">Email</label>
                        <input id="email" type="text" name="email" placeholder="you@example.com" required />
                    </div>
                    <div>
                        <label for="password">Password</label>
                        <input id="password" type="password" name="password" placeholder="Enter your password" required />
                    </div>
                    <button class="button-primary" type="submit">Login</button>
                </form>
            </div>
        </section>

        <footer class="footer">New to Shortify? <a href="/signup">Create an account</a> now.</footer>
    </div>
</body>
</html>